{
  "name": "autowhats",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "build": "echo 'Use install.sh for production build' && exit 0",
    "install:all": "npm install && npm run prisma:generate",
    "prisma:generate": "npm run prisma:generate -w api",
    "prisma:migrate": "npm run prisma:migrate -w api",
    "prisma:seed": "npm run prisma:seed -w api",
    "deploy:zip": "ts-node scripts/build-and-upload.ts"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/dotenv": "^6.1.1",
    "@types/fs-extra": "^11.0.4",
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "archiver": "^7.0.1",
    "fs-extra": "^11.3.4"
  }
}
