# ─────────────────────────────────────────
# AUTOWHATS — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env and fill in values
# cp .env.example .env

# ── App ──────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── Database (PostgreSQL) ─────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/autowhats

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Authentication ────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ── WhatsApp Cloud API ───────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_API_VERSION=v19.0
# Per-workspace: stored in DB (workspaces.meta_token, workspaces.phone_number_id)

# ── AI Providers ──────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o

GEMINI_API_KEY=AIza...
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Encryption ───────────────────────────
ENCRYPTION_KEY=32-char-secret-key-for-api-key-enc

# ── Logging ──────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log
